generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum CouponType {
  percent
  fixed
}

enum OrderStatus {
  pending
  paid
  shipped
  delivered
  cancelled
}

model Admin {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(120)
  email        String   @unique(map: "email") @db.VarChar(180)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([email], map: "idx_admins_email")
  @@map("admins")
}

model Customer {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(160)
  email     String     @db.VarChar(180)
  phone     String     @unique(map: "phone") @db.VarChar(32)
  address   String     @db.Text
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamp(0)
  favorites Favorite[]
  orders    Order[]

  @@index([phone], map: "idx_customers_phone")
  @@index([email], map: "idx_customers_email")
  @@map("customers")
}

model Product {
  id          Int         @id @default(autoincrement())
  sku         String?     @unique(map: "sku") @db.VarChar(80)
  name        String      @db.VarChar(180)
  description String?     @db.Text
  price       Decimal     @db.Decimal(10, 2)
  category    String      @default("pacotes") @db.VarChar(80)
  icon        String?     @default("PACK") @db.VarChar(32)
  stock       Int         @default(0)
  image       String?     @db.VarChar(600)
  imageUrl    String?     @map("image_url") @db.VarChar(600)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamp(0)
  favorites   Favorite[]
  orderItems  OrderItem[]
  stockMovements StockMovement[]

  @@index([category], map: "idx_products_category")
  @@index([stock], map: "idx_products_stock")
  @@fulltext([name, description, category], map: "ft_products_search")
  @@map("products")
}

model Coupon {
  id         Int        @id @default(autoincrement())
  code       String     @unique(map: "code") @db.VarChar(40)
  type       CouponType @default(percent)
  value      Decimal    @db.Decimal(10, 2)
  usageLimit Int?       @map("usage_limit")
  usedCount  Int        @default(0) @map("used_count")
  startsAt   DateTime?  @map("starts_at") @db.DateTime(0)
  expiresAt  DateTime?  @map("expires_at") @db.DateTime(0)
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamp(0)
  orders     Order[]

  @@index([code], map: "idx_coupons_code")
  @@map("coupons")
}

model Order {
  id         Int         @id @default(autoincrement())
  customerId Int         @map("customer_id")
  couponId   Int?        @map("coupon_id")
  subtotal   Decimal     @default(0) @db.Decimal(10, 2)
  discount   Decimal     @default(0) @db.Decimal(10, 2)
  total      Decimal     @default(0) @db.Decimal(10, 2)
  status     OrderStatus @default(pending)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamp(0)
  coupon     Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "fk_orders_coupon")
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_orders_customer")
  items      OrderItem[]
  stockMovements StockMovement[]

  @@index([status], map: "idx_orders_status")
  @@index([customerId], map: "idx_orders_customer")
  @@index([createdAt], map: "idx_orders_created_at")
  @@map("orders")
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  productId   Int?     @map("product_id")
  productName String   @map("product_name") @db.VarChar(180)
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  lineTotal   Decimal  @map("line_total") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "fk_order_items_order")
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "fk_order_items_product")

  @@index([orderId], map: "idx_order_items_order")
  @@index([productId], map: "idx_order_items_product")
  @@map("order_items")
}

model Favorite {
  id         Int       @id @default(autoincrement())
  customerId Int?      @map("customer_id")
  productId  Int       @map("product_id")
  sessionId  String?   @map("session_id") @db.VarChar(120)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "fk_favorites_customer")
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "fk_favorites_product")

  @@unique([customerId, productId], map: "uq_favorite_customer_product")
  @@index([sessionId], map: "idx_favorites_session")
  @@map("favorites")
}

model StockMovement {
  id        Int               @id @default(autoincrement())
  productId Int               @map("product_id")
  orderId   Int?              @map("order_id")
  type      StockMovementType
  quantity  Int
  reason    String            @db.VarChar(180)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamp(0)
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "fk_stock_movements_product")
  order     Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "fk_stock_movements_order")

  @@index([productId], map: "idx_stock_movements_product")
  @@index([orderId], map: "idx_stock_movements_order")
  @@index([createdAt], map: "idx_stock_movements_created_at")
  @@map("stock_movements")
}

enum StockMovementType {
  in
  out
  adjustment
}
